{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.ai/schemas/model-governance-ledger/workspace-prophet-ledger-entry.v0.1.schema.json",
  "title": "WorkspaceProphetLedgerEntry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ledger_entry_id",
    "entry_type",
    "readiness_state",
    "production_ready",
    "operation_ref",
    "capability_ref",
    "receipt_ref",
    "claim_ref",
    "evidence_thread_ref",
    "sherlock_packet_ref",
    "sociosphere_readiness_ref",
    "validated_evidence",
    "non_claims",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "ledger_entry_id": { "type": "string", "pattern": "^ledger_workspace_prophet_[a-z0-9_.-]+$" },
    "entry_type": { "type": "string", "const": "workspace_prophet_e2e_fixture" },
    "readiness_state": { "type": "string", "enum": ["planned", "fixture_validated", "runtime_observed", "production_ready", "blocked"] },
    "production_ready": { "type": "boolean", "const": false },
    "operation_ref": { "type": "string", "minLength": 1 },
    "capability_ref": { "type": "string", "minLength": 1 },
    "receipt_ref": { "type": "string", "minLength": 1 },
    "claim_ref": { "type": "string", "minLength": 1 },
    "evidence_thread_ref": { "type": "string", "minLength": 1 },
    "sherlock_packet_ref": { "type": "string", "minLength": 1 },
    "sociosphere_readiness_ref": { "type": "string", "minLength": 1 },
    "validated_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["repo", "command", "observed_state", "evidence_class"],
        "properties": {
          "repo": { "type": "string", "minLength": 1 },
          "command": { "type": "string", "minLength": 1 },
          "observed_state": { "type": "string", "enum": ["passed", "failed", "not_observed"] },
          "evidence_class": { "type": "string", "enum": ["local_user_observed", "ci_observed", "fixture_declared", "planned"] }
        }
      }
    },
    "non_claims": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "source_refs": { "type": "array", "items": { "type": "string" } },
    "metadata": { "type": "object", "additionalProperties": true },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
