{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SocioProphet/model-governance-ledger/schemas/governance-audit-record.v0.schema.json",
  "title": "Governance Audit Record v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "audit_id",
    "subject_ref",
    "policy_decision_ref",
    "source_quality",
    "implementation_safe",
    "trace_ref",
    "result",
    "provenance_refs"
  ],
  "properties": {
    "schema_version": {"const": "0.1"},
    "kind": {"const": "governance_audit_record"},
    "audit_id": {"type": "string", "minLength": 3},
    "subject_ref": {"type": "string", "minLength": 1},
    "policy_decision_ref": {"type": "string", "minLength": 1},
    "source_quality": {
      "enum": [
        "confirmed_official",
        "confirmed_bibliographic",
        "confirmed_pdf",
        "confirmed_artifact",
        "plausible_needs_source",
        "speculative_do_not_use"
      ]
    },
    "implementation_safe": {"type": "boolean"},
    "trace_ref": {"type": "string", "minLength": 1},
    "result": {"enum": ["allowed", "denied", "modified", "escalated", "recorded_only"]},
    "provenance_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
